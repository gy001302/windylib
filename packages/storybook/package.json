{
  "name": "@windylib/storybook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "mkdir -p .storybook-home && HOME=$PWD/.storybook-home XDG_CONFIG_HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -c .storybook --port 6006 --exact-port",
    "build": "mkdir -p .storybook-home && HOME=$PWD/.storybook-home XDG_CONFIG_HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build -c .storybook",
    "lint": "eslint .storybook src scripts --ext .js,.jsx,.mjs",
    "browser:monitor": "node scripts/monitor-browser.mjs"
  },
  "dependencies": {
    "@deck.gl/mapbox": "^9.2.11",
    "@luma.gl/core": "^9.2.6",
    "@luma.gl/engine": "^9.2.6",
    "@luma.gl/webgl": "^9.2.6",
    "@windylib/core": "workspace:*",
    "@windylib/maps": "workspace:*",
    "deck.gl": "^9.2.11",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.19.0",
    "playwright": "^1.53.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@vitejs/plugin-react": "^5.1.4",
    "storybook": "^8.6.14",
    "vite": "^5.4.19"
  }
}
