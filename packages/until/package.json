{
  "name": "@windylib/until",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly --declarationDir dist",
    "build": "pnpm run clean && pnpm run build:types && vite build"
  },
  "devDependencies": {
    "rollup-plugin-string": "^3.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.19"
  }
}
